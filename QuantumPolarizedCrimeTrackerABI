2. Connect to the Contract
Create a React component to interact with your contract:

Example: App.tsx
tsx
import React, { useState, useEffect } from "react";
import { ethers } from "ethers";
import QuantumPolarizedCrimeTrackerABI from "./artifacts/contracts/QuantumPolarizedCrimeTracker.sol/QuantumPolarizedCrimeTracker.json";

const CONTRACT_ADDRESS = "YOUR_DEPLOYED_CONTRACT_ADDRESS";

function App() {
  const [contract, setContract] = useState<ethers.Contract | null>(null);
  const [account, setAccount] = useState<string>("");
  const [crimeRecords, setCrimeRecords] = useState<any[]>([]);

  useEffect(() => {
    const init = async () => {
      if (window.ethereum) {
        const provider = new ethers.providers.Web3Provider(window.ethereum);
        const signer = provider.getSigner();
        const address = await signer.getAddress();
        setAccount(address);

        const contractInstance = new ethers.Contract(
          CONTRACT_ADDRESS,
          QuantumPolarizedCrimeTrackerABI.abi,
          signer
        );
        setContract(contractInstance);
      }
    };
    init();
  }, []);

  const fetchCrimeRecords = async () => {
    if (!contract) return;
    const count = await contract.getCrimeRecordCount();
    const records = [];
    for (let i = 0; i < count.toNumber(); i++) {
      const record = await contract.getCrimeRecord(i);
      records.push(record);
    }
    setCrimeRecords(records);
  };

  const recordCrime = async () => {
    if (!contract) return;
    const tx = await contract.recordCrime(
      "encryptedData",
      { x: 1, y: 2, z: 3, t: 4 }, // PolarizationVector
      { epsilon: 5, quantumEntropy: 6, encryptionKey: ethers.utils.formatBytes32String("key") }, // EpsilonZero
      "metadataCID",
      "APT23"
    );
    await tx.wait();
    fetchCrimeRecords();
  };

  return (
    <div>
      <h1>Quantum Crime Tracker</h1>
      <p>Connected Account: {account}</p>
      <button onClick={recordCrime}>Record Crime</button>
      <button onClick={fetchCrimeRecords}>Fetch Crime Records</button>
      <ul>
        {crimeRecords.map((record, index) => (
          <li key={index}>
            {record.threatGroup} - {record.timestamp.toString()}
          </li>
        ))}
      </ul>
    </div>
  );
}

export default App;
3. Deploy the Contract
Before connecting, deploy your contract to a testnet (e.g., Sepolia or Polygon Mumbai) using Hardhat:

Example: scripts/deploy.ts
typescript
import { ethers } from "hardhat";

async function main() {
  const QuantumPolarizedCrimeTracker = await ethers.getContractFactory("QuantumPolarizedCrimeTracker");
  const contract = await QuantumPolarizedCrimeTracker.deploy();
  await contract.deployed();
  console.log("Contract deployed to:", contract.address);
}

main().catch((error) => {
  console.error(error);
  process.exitCode = 1;
});
Run:

bash
npx hardhat run scripts/deploy.ts --network sepolia
4. Plug into CodeSandbox
Upload the ABI:

Export the ABI from artifacts/contracts/QuantumPolarizedCrimeTracker.sol/QuantumPolarizedCrimeTracker.json and save it in your CodeSandbox project.
Environment Setup:

Add the contract address and ABI to your frontend.
Use MetaMask for wallet connection.
Test:

Call recordCrime and fetchCrimeRecords to verify functionality.
